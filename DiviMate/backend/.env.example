# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/divimate

# JWT secret for auth tokens
JWT_SECRET=your_jwt_secret_here

# Server port
PORT=5000

# Gmail credentials for email reminders (use App Password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Set to "true" ONLY in development to enable the admin reset route
ADMIN_RESET=false
