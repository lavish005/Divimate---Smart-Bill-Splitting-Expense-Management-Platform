# ==========================================
# DiviMate - Root .gitignore
# ==========================================

# Dependencies
node_modules/
*/node_modules/
**/node_modules/

# Package lock files
package-lock.json
*/package-lock.json
**/package-lock.json
yarn.lock
pnpm-lock.yaml

# Environment variables
.env
.env.local
.env.*.local
*/.env
**/.env

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.iml
*.sublime-project
*.sublime-workspace

# Build outputs
dist/
build/
*/dist/
*/build/
**/dist/
**/build/

# Cache
.cache/
.eslintcache
.parcel-cache

# Testing
coverage/

# Misc
*.bak
*.tmp
